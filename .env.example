# Puerto (Railway inyecta PORT; en local usa 3000)
# PORT=3000
NODE_ENV=production

# CORS — URL pública del portfolio (HTTPS, sin barra final). Varias: separadas por coma
FRONTEND_ORIGIN="https://www.marianamarinflor.com,https://marianamarinflor.com"

# GitHub
GITHUB_USERNAME="marianamarinflor622"
LINKEDIN_PROFILE_URL="https://www.linkedin.com/in/mariana-marin-1b6268348"
GITHUB_TOKEN="ghp_tu_token_aqui"

# Opcional: secreto para ?refresh=1 en producción (header X-Refresh-Secret)
# ADMIN_REFRESH_SECRET="genera_un_secreto_largo"

# No guardar mensajes en disco (solo email). Recomendado en producción:
# CONTACT_PERSIST_MESSAGES=false
GITHUB_REPO_LIMIT=12
GITHUB_PUBLIC_REPO_COUNT=32
GITHUB_REPO_EXCLUDE="vibe-tracking"

# Formulario (Gmail: contraseña de aplicación)
CONTACT_TO="infomarianamarin@gmail.com"
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER="infomarianamarin@gmail.com"
SMTP_PASS="tu_contraseña_de_aplicacion"

# Render CLI/API (https://dashboard.render.com/u/settings#api-keys)
# RENDER_API_KEY=rnd_...
# RENDER_SERVICE_ID=srv-...
